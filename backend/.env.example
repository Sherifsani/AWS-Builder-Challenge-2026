# Copy to .env for local development
# --- DynamoDB ---
# When set, boto3 points at DynamoDB Local instead of AWS.
DYNAMODB_ENDPOINT_URL=http://localhost:8000
AWS_REGION=us-east-1
USERS_TABLE=Users
BULLETS_TABLE=ResumeBullets

# --- Auth ---
# Local-only secret. In prod this is read from SSM Parameter Store (see JWT_SECRET_PARAM).
JWT_SECRET=dev-only-change-me-please
JWT_SECRET_PARAM=/resume-tailor/jwt-secret
JWT_EXPIRE_MINUTES=1440

# --- Bedrock ---
BEDROCK_MODEL_ID=amazon.nova-lite-v1:0

# Local AWS creds for Bedrock (DynamoDB Local ignores these but boto3 needs them set)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
